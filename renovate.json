{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":semanticCommits",
        ":dependencyDashboard"
    ],
    "labels": ["dependencies"],
    "packageRules": [
        {
            "description": "Group dev tooling updates into a single PR.",
            "matchDepTypes": ["require-dev"],
            "groupName": "dev dependencies"
        },
        {
            "description": "Auto-merge patch/minor dev-tooling and GitHub Actions updates once CI is green.",
            "matchDepTypes": ["require-dev"],
            "matchUpdateTypes": ["minor", "patch"],
            "automerge": true
        },
        {
            "matchManagers": ["github-actions"],
            "matchUpdateTypes": ["minor", "patch"],
            "automerge": true
        }
    ]
}
